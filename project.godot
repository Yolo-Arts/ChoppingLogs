; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Game About Chopping Trees"
run/main_scene="uid://bd8pw5g1pc7gb"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://c4yl1rk2vmk1o"

[audio]

buses/default_bus_layout="res://Resources/default_bus_layout.tres"

[autoload]

SoundManager="res://AutoLoads/sound_manager.tscn"
Globals="*res://AutoLoads/Globals.gd"
TransitionManager="*res://AutoLoads/transition_manager.tscn"
EventSystem="*uid://8dn3brnlxu36"

[display]

window/size/viewport_width=1900
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "green",
"res://Assets/Audio/": "yellow",
"res://AutoLoads/": "red",
"res://Game/Config/": "red",
"res://Resources/": "gray",
"res://Shaders/": "purple"
}

